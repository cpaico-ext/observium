<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Demo role: Agrolait (base demo company) gets access to Observium dashboard -->
        <record id="portal_role_observium_demo" model="portal.partner.role">
            <field name="name">Observium Demo</field>
            <field name="client_id" ref="base.res_partner_2"/>
            <field name="contact_ids" eval="[
            (4, ref('base.res_partner_address_3')), 
            (4, ref('base.res_partner_address_4')), 
            (4, ref('base.res_partner_address_31'))
            ]"/>
            <field name="dashboard_ids" eval="[(4, ref('we_portal_observium.dashboard_observium'))]"/>
        </record>

        <record id="we_portal_observium.portal_role_observium_default" model="portal.partner.role">
            <field name="contact_ids" eval="[(4, ref('base.res_partner_main1')), (4, ref('base.res_partner_main2'))]"/>
        </record>
    </data>
</odoo>
