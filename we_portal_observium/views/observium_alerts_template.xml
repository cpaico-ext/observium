<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="observium_alerts_template" name="Observium: Alerts List">
    <t t-call="portal.portal_layout">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/my/home">Home</a></li>
                <li class="breadcrumb-item"><a href="/my/observium">Network Devices</a></li>
                <li class="breadcrumb-item active">Alerts</li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="obs-icon-wrap-lg">
                <i t-attf-class="fa fa-3x fa-bell {{ 'text-danger' if alert_count else 'text-success' }}"/>
            </div>
            <div class="flex-grow-1">
                <h2 class="mb-0">Active Alerts</h2>
                <p class="text-muted mb-0">Network monitoring alarms from Observium</p>
            </div>
            <!-- Status filter -->
            <div class="btn-group btn-group-sm" role="group">
                <a t-attf-href="/my/observium/alerts?status=failed"
                   t-attf-class="btn {{ 'btn-danger' if status == 'failed' else 'btn-outline-danger' }}">
                    Failed
                </a>
                <a t-attf-href="/my/observium/alerts?status=failed_suppressed"
                   t-attf-class="btn {{ 'btn-warning' if status == 'failed_suppressed' else 'btn-outline-warning' }}">
                    Suppressed
                </a>
                <a t-attf-href="/my/observium/alerts?status=delayed"
                   t-attf-class="btn {{ 'btn-secondary' if status == 'delayed' else 'btn-outline-secondary' }}">
                    Delayed
                </a>
            </div>
            <a href="/my/observium" class="btn btn-outline-secondary btn-sm">
                <i class="fa fa-arrow-left me-1"/>Devices
            </a>
        </div>

        <!-- Error -->
        <t t-if="error">
            <div class="alert alert-danger d-flex gap-3 align-items-start">
                <i class="fa fa-exclamation-triangle fa-2x mt-1 flex-shrink-0"/>
                <div>
                    <strong>Error loading alerts</strong>
                    <p class="mb-0 small" t-esc="error"/>
                </div>
            </div>
        </t>

        <!-- Status OK — no alerts -->
        <t t-if="not alerts and not error">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="fa fa-check-circle fa-3x text-success mb-3"/>
                    <h4 class="text-success">All clear</h4>
                    <p class="text-muted small">No alerts with status "<t t-esc="status"/>" at this time.</p>
                </div>
            </div>
        </t>

        <!-- Alert table -->
        <t t-if="alerts">
            <div class="obs-summary-bar mb-4">
                <div class="obs-stat">
                    <i t-attf-class="fa fa-bell {{ 'text-danger' if alert_count else 'text-muted' }}"/>
                    <div>
                        <span t-attf-class="obs-stat-value {{ 'text-danger' if alert_count else '' }}">
                            <t t-esc="alert_count"/>
                        </span>
                        <span class="obs-stat-label d-block">Total alerts</span>
                    </div>
                </div>
                <div class="obs-stat">
                    <i class="fa fa-server text-primary"/>
                    <div>
                        <span class="obs-stat-value">
                            <t t-esc="len(set(str(a.get('device_id','')) for a in alerts))"/>
                        </span>
                        <span class="obs-stat-label d-block">Devices affected</span>
                    </div>
                </div>
            </div>

            <div class="card border-1 shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Alert</th>
                                <th>Device</th>
                                <th>Entity</th>
                                <th>Status</th>
                                <th>Since</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="alerts" t-as="alert">
                                <t t-set="a_status" t-value="alert.get('status', '')"/>
                                <tr>
                                    <td class="small fw-bold">
                                        <t t-esc="alert.get('alert_test_name') or alert.get('alert_name', 'N/A')"/>
                                    </td>
                                    <td class="small">
                                        <a t-attf-href="/my/observium/{{ alert.get('device_id', '') }}"
                                           class="text-decoration-none">
                                            <i class="fa fa-server me-1 text-muted"/>
                                            <t t-esc="alert.get('hostname') or alert.get('device_id', 'N/A')"/>
                                        </a>
                                    </td>
                                    <td class="small">
                                        <span class="badge bg-info bg-opacity-20 text-dark border border-dark border-opacity-10"
                                              t-esc="alert.get('entity_type', 'N/A')"/>
                                        <span class="ms-1 text-muted" t-esc="alert.get('entity_name', '')"/>
                                    </td>
                                    <td>
                                        <span t-attf-class="badge {{ 'bg-danger' if a_status == 'failed' else 'bg-warning text-dark' if a_status == 'delayed' else 'bg-secondary' }}">
                                            <t t-esc="a_status"/>
                                        </span>
                                    </td>
                                    <td class="small text-muted">
                                        <t t-esc="alert.get('last_changed') or alert.get('alert_timestamp', 'N/A')"/>
                                    </td>
                                    <td>
                                        <a t-attf-href="/my/observium/{{ alert.get('device_id', '') }}#tab-alerts"
                                           class="btn btn-outline-secondary btn-sm py-0 px-2"
                                           title="View on device">
                                            <i class="fa fa-arrow-right"/>
                                        </a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </t>

    </t>
</template>

</odoo>