<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        This template is assigned as template_id of the portal.dashboard.element
        created in data/portal_dashboard_data.xml.
        It renders an embedded preview / entry point for Observium devices
        inside a dashboard card.
    -->
    <template id="dashboard_element_observium" name="Dashboard Element: Observium Devices">

        <div class="obs-dashboard-element">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="obs-icon-wrap">
                    <i class="fa fa-2x fa-server text-primary"/>
                </div>
                <div>
                    <h5 class="mb-0">Network Monitoring</h5>
                    <p class="text-muted small mb-0">
                        Powered by Observium
                    </p>
                </div>
                <a href="/my/observium" class="btn btn-primary btn-sm ms-auto">
                    <i class="fa fa-arrow-right me-1"/>View devices
                </a>
            </div>

            <p class="text-muted small mb-0">
                <i class="fa fa-info-circle me-1"/>
                Click "View devices" to see your monitored network infrastructure,
                real-time metrics and performance graphs.
            </p>
        </div>

    </template>

</odoo>
