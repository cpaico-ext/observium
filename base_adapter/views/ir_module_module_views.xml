<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="app_module_view_kanban" model="ir.ui.view">
        <field name="name">ir.module.module.kanban.inherit.base</field>
        <field name="model">ir.module.module</field>
        <field name="inherit_id" ref="base.module_view_kanban"/>
        <field name="arch" type="xml">
            
            <xpath expr="//t[@t-name='card']" position="attributes">
                <attribute name="class" add="oe_kanban_global_click" separator=" "/>
            </xpath>

            <xpath expr="//button[@name='button_immediate_install']" position="after">
                <button type="object" 
                        class="btn btn-primary btn-sm" 
                        name="button_immediate_upgrade" 
                        invisible="state != 'installed'" 
                        groups="base_adapter.group_show_quick_upgrade">Upgrade</button>
                <button type="object" 
                        class="btn btn-secondary btn-sm" 
                        name="button_uninstall_wizard" 
                        invisible="state != 'installed'" 
                        groups="base_adapter.group_show_quick_upgrade">Uninstall</button>
            </xpath>

            <xpath expr="//t[@t-name='menu']" position="inside">
                <a t-if="record.state.raw_value == 'installed'" 
                   name="%(base_adapter.action_server_module_multi_get_po)d" 
                   type="action" 
                   role="menuitem" 
                   class="dropdown-item">Export Translation</a>
                <a t-if="record.state.raw_value == 'installed'" 
                   name="%(base_adapter.action_server_module_multi_refresh_po)d" 
                   type="action" 
                   role="menuitem" 
                   class="dropdown-item">Refresh Translation</a>
            </xpath>

        </field>
    </record>
</odoo>