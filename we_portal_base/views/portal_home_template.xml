<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Inherit portal home to inject accessible dashboards.
        Replaces the hardcoded entries from the original module with a
        dynamic list driven by portal.partner.role assignments.
    -->
    <template id="portal_my_home_dashboards"
              name="Portal: My Dashboards"
              inherit_id="portal.portal_my_home"
              priority="20">

        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">

            <!-- Dashboard cards section -->
            <t t-if="accessible_dashboards">
                <div class="o_portal_category mb-4">
                    <div class="o_portal_category_header d-flex align-items-center mb-3">
                        <i class="fa fa-tachometer fa-fw me-2 text-primary"/>
                        <h4 class="mb-0">My Dashboards</h4>
                    </div>

                    <div class="row g-3">
                        <t t-foreach="accessible_dashboards" t-as="db">
                            <div class="col-xl-3 col-lg-4 col-md-6">
                                <a t-att-href="db.url" class="text-decoration-none">
                                    <div class="card h-100 border-0 shadow-sm portal-dashboard-card">
                                        <div class="card-body d-flex flex-column align-items-center text-center p-4">
                                            <!-- Icon -->
                                            <div class="portal-dashboard-icon mb-3">
                                                <t t-if="db.icon_type == 'image' and db.icon_image">
                                                    <img t-attf-src="/web/image/portal.dashboard/{{ db.id }}/icon_image"
                                                         class="rounded" style="width:80px;height:80px;object-fit:contain;"/>
                                                </t>
                                                <t t-else="">
                                                    <i t-attf-class="fa fa-2x {{ db.icon or 'fa-tachometer' }} text-primary"/>
                                                </t>
                                            </div>
                                            <!-- Title -->
                                            <h5 class="card-title mb-1" t-esc="db.name"/>
                                            <!-- Description -->
                                            <p t-if="db.description"
                                               class="card-text text-muted small mb-0"
                                               t-esc="db.description"/>
                                        </div>
                                        <div class="card-footer bg-transparent border-top text-center py-2">
                                            <small class="text-primary">
                                                <i class="fa fa-arrow-right me-1"/>View dashboard
                                            </small>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </t>
                    </div>
                </div>
            </t>

            <!-- Empty state -->
            <t t-else="">
                <div class="o_portal_category mb-4">
                    <div class="alert alert-info d-flex align-items-center gap-3" role="alert">
                        <i class="fa fa-info-circle fa-2x"/>
                        <div>
                            <strong>No dashboards assigned</strong>
                            <p class="mb-0 small">Contact your administrator to request access to a dashboard.</p>
                        </div>
                    </div>
                </div>
            </t>

        </xpath>
    </template>

</odoo>