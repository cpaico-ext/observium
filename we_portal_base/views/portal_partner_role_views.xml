<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_portal_partner_role_list" model="ir.ui.view">
        <field name="name">portal.partner.role.list</field>
        <field name="model">portal.partner.role</field>
        <field name="arch" type="xml">
            <list string="Partner Roles">
                <field name="name"/>
                <field name="client_id" widget="many2one_avatar"/>
                <field name="contact_ids" widget="many2many_tags" optional="hide"/>
                <field name="dashboard_ids" widget="many2many_tags" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_portal_partner_role_form" model="ir.ui.view">
        <field name="name">portal.partner.role.form</field>
        <field name="model">portal.partner.role</field>
        <field name="arch" type="xml">
            <form string="Portal Partner Role">
                <header>
                    <field name="active" invisible="True"/>
                    <button name="action_grant_portal_access"
                            type="object"
                            string="Grant Portal Access"
                            class="btn-primary"
                            icon="fa-user-plus"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-toggle-on"
                                invisible="not active">
                            <div class="o_stat_info">
                                <span class="o_stat_text text-success">Active</span>
                            </div>
                        </button>
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-toggle-off"
                                invisible="active">
                            <div class="o_stat_info">
                                <span class="o_stat_text text-muted">Inactive</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Role name..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="client_id" widget="many2one_avatar"/>
                    </group>
                    <notebook>
                        <page string="Contacts" name="contacts" autofocus="autofocus">
                            <field name="contact_ids"
                                mode="kanban"
                                widget="many2many_kanban"
                                context="{
                                    'default_parent_id': client_id,
                                    'default_is_company': False,
                                    'default_type': 'contact',
                                    'list_view_ref': 'we_portal_base.view_partner_list_for_partner_role',
                                    'kanban_view_ref': 'we_portal_base.view_partner_kanban_for_partner_role',
                                    'form_view_ref': 'we_portal_base.view_partner_form_for_partner_role'
                                }"/>
                        </page>
                        <page string="Dashboards" name="dashboards">
                            <field name="dashboard_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code" optional="show"/>
                                    <field name="description" optional="show"/>
                                    <field name="url" optional="show"/>
                                    <field name="element_ids" widget="many2many_tags" optional="show"/>
                                    <field name="active" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_portal_partner_role_search" model="ir.ui.view">
        <field name="name">portal.partner.role.search</field>
        <field name="model">portal.partner.role</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_id"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_portal_partner_role" model="ir.actions.act_window">
        <field name="name">Partner Roles</field>
        <field name="res_model">portal.partner.role</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a partner role and assign dashboards to clients.
            </p>
        </field>
    </record>

    <!-- Menu item -->
    <menuitem
        id="menu_portal_partner_role"
        name="Partner Roles"
        parent="menu_portal_root"
        action="action_portal_partner_role"
        sequence="30"
        groups="we_portal_base.group_manager"/>

</odoo>
