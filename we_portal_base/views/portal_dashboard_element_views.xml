<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_portal_dashboard_element_list" model="ir.ui.view">
        <field name="name">portal.dashboard.element.list</field>
        <field name="model">portal.dashboard.element</field>
        <field name="arch" type="xml">
            <list string="Dashboard elements">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="template_id"/>
                <field name="dashboard_ids" widget="many2many_tags"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_portal_dashboard_element_form" model="ir.ui.view">
        <field name="name">portal.dashboard.element.form</field>
        <field name="model">portal.dashboard.element</field>
        <field name="arch" type="xml">
            <form string="Dashboard element">
                <header>
                    <field name="active" invisible="True"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-toggle-on"
                                invisible="not active">
                            <div class="o_stat_info">
                                <span class="o_stat_text text-success">Active</span>
                            </div>
                        </button>
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-toggle-off"
                                invisible="active">
                            <div class="o_stat_info">
                                <span class="o_stat_text text-muted">Inactive</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="element name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence" invisible="1"/>
                        </group>
                        <group>
                            <field name="template_id"
                                   options="{'no_create': True}"
                                   help="Select a QWeb template to render for this element"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dashboards" name="dashboards">
                            <field name="dashboard_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="icon"/>
                                    <field name="url"/>
                                </list>
                                <form>
                                    <sheet>
                                        <div class="oe_title">
                                            <label for="name"/>
                                            <h1>
                                                <field name="name" placeholder="Dashboard name..."/>
                                            </h1>
                                        </div>
                                        <group>
                                            <group>
                                                <field name="code"/>
                                                <field name="icon" placeholder="fa-eye"/>
                                                <field name="sequence" invisible="1"/>
                                            </group>
                                            <group>
                                                <field name="url" readonly="1"/>
                                                <field name="description"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_portal_dashboard_element" model="ir.actions.act_window">
        <field name="name">Dashboard elements</field>
        <field name="res_model">portal.dashboard.element</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create your first dashboard element.
            </p>
        </field>
    </record>

    <!-- Menu element -->
    <menuitem
        id="menu_portal_dashboard_element"
        name="Elements"
        parent="menu_portal_dashboard"
        action="action_portal_dashboard_element"
        sequence="20"
        groups="we_portal_base.group_admin"/>

</odoo>
